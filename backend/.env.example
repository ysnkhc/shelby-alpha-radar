# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shelby_indexer

# Redis connection string
REDIS_URL=redis://localhost:6379

# Shelby RPC endpoint (blob retrieval)
SHELBY_RPC_URL=https://api.shelbynet.shelby.xyz

# Aptos RPC endpoint (blockchain event scanning)
# Shelbynet has its own Aptos fullnode — this is where blob events live
APTOS_RPC_URL=https://api.shelbynet.shelby.xyz/v1

# Server port
PORT=3000

# Node environment
NODE_ENV=development
