// Shelby Indexer — Prisma Schema
// Core data model for blob indexing, project intelligence, and search.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core blob record — one entry per unique blob discovered on the Shelby network.
model Blob {
  id          Int       @id @default(autoincrement())
  blobId      String    @unique @map("blob_id")
  wallet      String
  size        BigInt    @default(0)
  contentType String?   @map("content_type")
  projectId   String?   @map("project_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  indexedAt   DateTime  @default(now()) @map("indexed_at")

  /// One-to-one relation: each blob has at most one metadata record.
  metadata    BlobMetadata?

  @@index([wallet])
  @@index([createdAt])
  @@index([projectId])
  @@map("blobs")
}

/// Extended metadata extracted from a blob after processing.
model BlobMetadata {
  id              Int      @id @default(autoincrement())
  blobId          String   @unique @map("blob_id")
  title           String?
  description     String?
  tags            String[] @default([])
  fileType        String?  @map("file_type")
  signals         String[] @default([])
  analysisStatus  String   @default("pending") @map("analysis_status")
  contentPreview  String?  @map("content_preview")

  blob            Blob     @relation(fields: [blobId], references: [blobId], onDelete: Cascade)

  @@map("blob_metadata")
}

/// Discovered project — cross-wallet clustering of related blobs.
model Project {
  id          String   @id @map("project_id")
  label       String
  category    String   @default("general")
  wallets     String[] @default([])
  tags        String[] @default([])
  signals     String[] @default([])
  fileTypes   String[] @default([]) @map("file_types")
  blobCount   Int      @default(0) @map("blob_count")
  walletCount Int      @default(0) @map("wallet_count")
  growthRate  Float    @default(0) @map("growth_rate")
  firstSeen   DateTime @default(now()) @map("first_seen")
  lastActive  DateTime @default(now()) @map("last_active")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([category])
  @@index([walletCount])
  @@index([blobCount])
  @@index([lastActive])
  @@map("projects")
}

/// Crawler state persistence — stores key-value pairs for resumable scanning.
model CrawlerState {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("crawler_state")
}

/// High-signal events detected from blob activity patterns.
model AlphaEvent {
  id          Int      @id @default(autoincrement())
  owner       String
  blobName    String?  @map("blob_name")
  signalType  String   @map("signal_type")
  score       Int
  priority    String   @default("LOW")
  explanation String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([owner])
  @@index([score])
  @@index([priority])
  @@index([createdAt])
  @@map("alpha_events")
}

/// Structured dataset built from a project's blobs.
model Dataset {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  type      String   @default("unknown") // classification | rag | timeseries | unknown
  status    String   @default("building") // building | ready | failed
  schema    Json?
  rowCount  Int      @default(0) @map("row_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  versions  DatasetVersion[]

  @@index([projectId])
  @@map("datasets")
}

/// Immutable snapshot of a dataset at a point in time.
model DatasetVersion {
  id        String   @id @default(cuid())
  datasetId String   @map("dataset_id")
  version   Int
  blobIds   String[] @default([]) @map("blob_ids")
  schema    Json?
  rowCount  Int      @default(0) @map("row_count")
  createdAt DateTime @default(now()) @map("created_at")

  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@map("dataset_versions")
}
