{
  "name": "shelby-indexer",
  "version": "1.0.0",
  "description": "Indexing and search engine for Shelby Protocol decentralized storage",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "postinstall": "prisma generate --schema=src/database/prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shelby",
    "indexer",
    "blockchain",
    "storage",
    "search"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@prisma/client": "^6.4.1",
    "axios": "^1.13.6",
    "bullmq": "^5.34.8",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  }
}
